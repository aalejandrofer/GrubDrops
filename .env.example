# Required: age secret key (generate once with `age-keygen`)
GRUB_MASTER_KEY=AGE-SECRET-KEY-1XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX0

# Optional overrides
GRUB_HTTP_ADDR=0.0.0.0:8080
GRUB_DB_PATH=/data/miner.db

# Optional: Discord webhook URL for state/progress/claim/error notifications.
# Leave empty to disable Discord (falls back to log-only NoopNotifier).
GRUB_DISCORD_WEBHOOK=

# Set to true when the daemon is behind a TLS terminator (Traefik, nginx).
# Forces the session cookie to be sent only over HTTPS. Leave false for
# local HTTP testing.
GRUB_SECURE_COOKIES=false

# Set to "browser:9090" and start with `docker compose --profile browser up`
# to enable the Kick backend. Leave empty to disable Kick.
GRUB_BROWSER_URL=
